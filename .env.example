# ─────────────────────────────────────────────────────────────────────────────
# Hospital Blockchain — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask Server ─────────────────────────────────────────────────────────────
# Host to bind the Flask server. Use 127.0.0.1 for local development.
# Only change to 0.0.0.0 for explicit container/cloud deployments.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ── Admin Reset Token ────────────────────────────────────────────────────────
# A cryptographically random secret that protects the /reset endpoint.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
RESET_TOKEN=CHANGE_ME_generate_a_random_secret_here

# ── API Authentication ────────────────────────────────────────────────────────
# Bearer token required in the X-API-Key header for protected endpoints.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=CHANGE_ME_generate_a_random_api_key_here

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" ONLY in explicit demo/educational environments.
# When false (default), the /update_file and /get_files hack-simulator
# endpoints are disabled (404).
DEMO_MODE=false

# ── Private Keys (PEM format, one per user) ──────────────────────────────────
# Run keygen.py to auto-generate these and populate your .env file.
# Do NOT share or commit these values.
PRIVATE_KEY_DOC_505=
PRIVATE_KEY_DOC_911=
PRIVATE_KEY_REC_101=
PRIVATE_KEY_NUR_202=
